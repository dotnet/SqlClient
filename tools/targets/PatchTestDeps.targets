<!--
  Workaround: the SqlClient project's custom OutputPath prevents the SDK from
  emitting a runtime entry in the consumer's deps.json. Patch it post-build so
  child processes (e.g. RemoteExecutor) can resolve the assembly.
-->
<Project>

  <Import Project="$(RepoRoot)src/Microsoft.Data.SqlClient/MdsVersions.props"
          Condition="'$(MdsPackageVersion)' == '' OR '$(MdsAssemblyVersion)' == ''" />

  <Target Name="_PatchDepsJsonForSqlClient"
          AfterTargets="GenerateBuildDependencyFile"
          Condition="Exists('$(ProjectDepsFilePath)')">
    <PatchDepsJson DepsFilePath="$(ProjectDepsFilePath)"
                   PackageId="Microsoft.Data.SqlClient"
                   PackageVersion="$(MdsPackageVersion)"
                   AssemblyVersion="$(MdsAssemblyVersion)" />
  </Target>

  <UsingTask TaskName="PatchDepsJson"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <DepsFilePath ParameterType="System.String" Required="true" />
      <PackageId    ParameterType="System.String" Required="true" />
      <PackageVersion ParameterType="System.String" Required="true" />
      <AssemblyVersion ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.Text.RegularExpressions" />
      <Code Type="Fragment" Language="cs"><![CDATA[
string key  = "\"" + PackageId + "/" + PackageVersion + "\"";
string json = System.IO.File.ReadAllText(DepsFilePath);

// Already has a runtime entry — nothing to do.
int ki = json.IndexOf(key);
if (ki >= 0 && json.Substring(ki, System.Math.Min(200, json.Length - ki)).Contains("\"runtime\""))
    return true;

// Inject target entry with runtime section.
string block = key + @": {
        ""dependencies"": {},
        ""runtime"": { """ + PackageId + @".dll"": { ""assemblyVersion"": """ + AssemblyVersion + @""", ""fileVersion"": """ + AssemblyVersion + @""" } }
      }, ";
var m = Regex.Match(json, @"""\.NETCoreApp[^""]*""\s*:\s*\{");
if (m.Success)
    json = json.Insert(m.Index + m.Length, "\n      " + block);

// Inject library entry if missing.
int li = json.IndexOf("\"libraries\"");
if (li >= 0)
{
    int lb = json.IndexOf("{", li + 11);
    if (lb >= 0 && json.IndexOf(key, lb) < 0)
        json = json.Insert(lb + 1, "\n    " + key + @": { ""type"": ""project"", ""serviceable"": false, ""sha512"": """" },");
}

System.IO.File.WriteAllText(DepsFilePath, json);
Log.LogMessage(MessageImportance.High, "Patched " + System.IO.Path.GetFileName(DepsFilePath) + ": added runtime entry for " + PackageId + "/" + PackageVersion);
]]></Code>
    </Task>
  </UsingTask>

</Project>
