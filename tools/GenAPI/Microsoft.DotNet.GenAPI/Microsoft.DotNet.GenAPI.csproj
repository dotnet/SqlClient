<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <ExcludeFromSourceBuild>true</ExcludeFromSourceBuild>
    <PackageType>MSBuildSdk</PackageType>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IsPackable>true</IsPackable>
    <NoWarn>$(NoWarn);0436</NoWarn>
  </PropertyGroup>

  <!-- Target Framework ================================================ -->
  <PropertyGroup>
    <!--
      We only need one version of this project to be built.
      NOTE: This should not be changed to a netfx target, as we expect to be able to run GenAPI on
          any OS via the dotnet command.
    -->
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <!-- References ====================================================== -->
  <ItemGroup>
    <ProjectReference Include="..\Microsoft.Cci.Extensions\Microsoft.Cci.Extensions.csproj" />

    <PackageReference Include="McMaster.Extensions.CommandLineUtils" />
    <PackageReference Include="System.Diagnostics.TextWriterTraceListener" />
    <PackageReference Include="System.Diagnostics.TraceSource" />
    <PackageReference Include="System.Private.Uri" />
  </ItemGroup>
</Project>
