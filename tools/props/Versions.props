<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Common Package Properties -->
  <PropertyGroup>
    <BuildNumber Condition="'$(BuildNumber)' == ''">0</BuildNumber>
    <!--
      Build numbers from CI pipelines may be in format "XXXXX.YY".
      Extract just the first part before any decimal point for use in
      assembly version components (which must be 16-bit unsigned integers).
    -->
    <AssemblyBuildNumber>$(BuildNumber.Split('.')[0])</AssemblyBuildNumber>
  </PropertyGroup>

  <!-- SqlServer Package Properties -->
  <PropertyGroup>
    <!-- This version section corresponds to version info of Microsoft.SqlServer.Server Assembly. -->
    <!-- Should only be changed in future when a non-backwards compatible driver is released. -->
    <!-- Future Assembly Version values shall be Major.Minor.0.0; e.g. 1.0.0.0 -->
    <SqlServerAssemblyVersion>1.0.0.0</SqlServerAssemblyVersion>
    <SqlServerAssemblyFileVersion Condition="'$(SqlServerAssemblyFileVersion)' == ''">1.0.0.0</SqlServerAssemblyFileVersion>
    <SqlServerPackageVersion Condition="'$(SqlServerPackageVersion)' == ''">1.0.0.$(BuildNumber)-dev</SqlServerPackageVersion>
    <SqlServerVersion>$(SqlServerPackageVersion)</SqlServerVersion>
  </PropertyGroup>

  <!-- Abstractions Package Properties -->
  <Import Project="..\..\src\Microsoft.Data.SqlClient.Extensions\Abstractions\src\AbstractionsVersions.props" />

  <!-- Logging Package Properties -->
  <Import Project="..\..\src\Microsoft.Data.SqlClient.Extensions\Logging\src\LoggingVersions.props" />

  <!-- For MDS Versioning, see src/Microsoft.Data.SqlClient/MdsVersions.props -->

  <!-- Azure Package Properties -->
  <Import Project="..\..\src\Microsoft.Data.SqlClient.Extensions\Azure\src\AzureVersions.props" />

  <!-- AKV Package Properties -->
  <PropertyGroup>
    <AkvVersionDefault>7.0.0</AkvVersionDefault>
    <AkvPackageVersion Condition="'$(AkvPackageVersion)' == ''">$(AkvVersionDefault).$(BuildNumber)-dev</AkvPackageVersion>
  </PropertyGroup>
</Project>
