<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net462;net8.0;net9.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <AssemblyName>Microsoft.Data.SqlClient.Extensions.Azure.Test</AssemblyName>
  </PropertyGroup>

  <!-- Hack to support the SNI native DLL copying below. -->
  <PropertyGroup Condition="'$(ApplyMdsAssemblyNameSuffix)' == 'true'">
    <MdsNetFxSuffix>.NetFx</MdsNetFxSuffix>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../src/Azure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="xunit.runner.console" />
    <PackageReference Include="Microsoft.DotNet.XUnitExtensions" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <!-- Copy the xUnit config file to our artifacts. -->
  <ItemGroup>
    <ContentWithTargetPath Include="../../../Microsoft.Data.SqlClient/tests/tools/Microsoft.Data.SqlClient.TestUtilities/xunit.runner.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>xunit.runner.json</TargetPath>
    </ContentWithTargetPath>
  </ItemGroup>

  <!--
    Depend on the TestUtilities project because it copies the JSON config for
    tests into the artifacts.  We don't refer to any of its assemblies.
  -->
  <ItemGroup>
    <ProjectReference Include="../../../Microsoft.Data.SqlClient/tests/tools/Microsoft.Data.SqlClient.TestUtilities/Microsoft.Data.SqlClient.TestUtilities.csproj" />
  </ItemGroup>

  <!-- Conditional Project References -->
  <ItemGroup Condition="'$(ReferenceType)' == 'Project'">
    <!--
      Include the .NET or .NET Framework MDS project depending on which
      framework we are targeting.
    -->
    <ProjectReference
      Condition="'$(TargetFramework)' != 'net462'"
      Include="$(NetCoreSource)src\Microsoft.Data.SqlClient.csproj" />
    <ProjectReference
      Condition="'$(TargetFramework)' == 'net462'"
      Include="$(NetFxSource)src\Microsoft.Data.SqlClient.csproj" />

    <!--
      This is a hack to ensure that the SNI native DLLs are included with our
      artifacts for .NET Framework.  Interestingly, they seem to be included
      automatically for .NET - shrug!
    -->
    <ContentWithTargetPath
      Condition="'$(TargetFramework)' == 'net462'"
      Include="$(BinFolder)$(Configuration).AnyCPU/Microsoft.Data.SqlClient$(MdsNetFxSuffix)/netfx/net462/*SNI*.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>%(Filename)%(Extension)</TargetPath>
    </ContentWithTargetPath>
  </ItemGroup>

  <!-- Conditional Package References -->
  <ItemGroup Condition="'$(ReferenceType)' == 'Package'">
    <PackageReference Include="Microsoft.Data.SqlClient" />
  </ItemGroup>

</Project>
