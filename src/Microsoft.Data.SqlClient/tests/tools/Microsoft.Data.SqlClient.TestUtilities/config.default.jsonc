{
    // Typical Windows SQL Server on the local host via TCP.
    "TCPConnectionString": "Data Source=tcp:localhost;Database=Northwind;Integrated Security=true;Encrypt=false;",

    // Typical Linux SQL Server on the local host, WSL, or a container, via TCP.
