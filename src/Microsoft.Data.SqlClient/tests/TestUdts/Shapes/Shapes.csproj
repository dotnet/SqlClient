<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Shapes</RootNamespace>
    <AssemblyName>Shapes</AssemblyName>
  </PropertyGroup>

  <!-- Target Frameworks =============================================== -->
  <PropertyGroup>
    <TargetFrameworks>net462;net8.0;net9.0;net10.0</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)src/Microsoft.SqlServer.Server/Microsoft.SqlServer.Server.csproj"
                      Condition="'$(ReferenceType)' != 'Package'" />
    <PackageReference Include="Microsoft.SqlServer.Server"
                      Condition="'$(ReferenceType)' == 'Package'" />
  </ItemGroup>
</Project>
