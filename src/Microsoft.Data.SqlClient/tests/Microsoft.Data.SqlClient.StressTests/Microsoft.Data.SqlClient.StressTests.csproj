<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net9.0;net481</TargetFrameworks>
    <Nullable>warnings</Nullable>
  </PropertyGroup>
  
  <PropertyGroup>
    <TargetGroup Condition="$(TargetFramework.StartsWith('net4'))">netfx</TargetGroup>
    <TargetGroup Condition="'$(TargetGroup)' == ''">netcoreapp</TargetGroup>
  </PropertyGroup>

  <!-- Special Files ====================================================== -->
  <ItemGroup>
    <None Update="StressTest.config">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  
  <!-- References ========================================================= -->
  <ItemGroup>
    <!-- @TODO: Replace with reference to common project when it's ready -->
    <ProjectReference Include="$(NetCoreSource)src\Microsoft.Data.SqlClient.csproj"
                      Condition="'$(TargetGroup)'=='netcoreapp' AND '$(ReferenceType)'=='Project'" />
    <ProjectReference Include="$(NetFxSource)src\Microsoft.Data.SqlClient.csproj"
                      Condition="'$(TargetGroup)'=='netfx' AND '$(ReferenceType)'=='Project'" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient"
                      Condition="$(ReferenceType.Contains('Package'))" />
  </ItemGroup>
</Project>
