<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    This file contains the AKV Provider package version information.  It is
    separate from the AKV Provider .csproj file so these versions can be imported into
    the overall MDS build without including other project variables.

    Private properties, not intended to be set or used externally, are prefixed
    with an underscore (_).
  -->

  <!-- This file uses several properties defined in tools/props/Versions.props. -->

  <!-- Versioning Properties -->
  <PropertyGroup>
    <!--
      We accept two public properties to control versioning:

        AkvPackageVersion:
          - Used as the NuGet package version, both in the package file name
            and in the package metadata.
          - If not specified, defaults to:
              $(AkvDefaultMajorVersion).$(AkvDefaultMinorVersion).0.$(BuildNumber)-dev.

        AkvAssemblyFileVersion:
          - Used as the value of the assembly attribute 'AssemblyFileVersion'
            generated by MSBuild.
          - If not specified:
            - If $(AkvPackageVersion) is specified, use the numeric
              parts of its value, for example 6.1.2.345.
            - Otherwise, defaults to:
              $(AkvDefaultMajorVersion).$(AkvDefaultMinorVersion).0.$(BuildNumber).

      We use private properties to hold the computed values, and then always
      assign those to the public properties.  After importing this file, the
      public properties will always be set.
    -->

    <!-- The default major and minor version numbers. -->
    <AkvDefaultMajorVersion>6</AkvDefaultMajorVersion>
    <AkvDefaultMinorVersion>1</AkvDefaultMinorVersion>

    <!-- Determine the package version. -->
    <_AkvPackageVersion Condition="'$(AkvPackageVersion)' != ''">$(AkvPackageVersion)</_AkvPackageVersion>
    <_AkvPackageVersion Condition="'$(AkvPackageVersion)' == ''">$(AkvDefaultMajorVersion).$(AkvDefaultMinorVersion).0.$(BuildNumber)-dev</_AkvPackageVersion>

    <!-- Determine the assembly file version. -->
    <!-- If AkvAssemblyFileVersion is set, use its value as-is. -->
    <_AkvAssemblyFileVersion Condition="'$(AkvAssemblyFileVersion)' != ''">$(AkvAssemblyFileVersion)</_AkvAssemblyFileVersion>
    <!-- If AkvPackageVersion is set, use its trimmed value. -->
    <_AkvAssemblyFileVersion Condition="'$(AkvAssemblyFileVersion)' == '' and '$(AkvPackageVersion)' != ''">$(AkvPackageVersion.Split('-')[0])</_AkvAssemblyFileVersion>
    <!-- If neither property is set, use the default value. -->
    <_AkvAssemblyFileVersion Condition="'$(AkvAssemblyFileVersion)' == '' and '$(AkvPackageVersion)' == ''">$(AkvDefaultMajorVersion).$(AkvDefaultMinorVersion).0.$(BuildNumber)</_AkvAssemblyFileVersion>

    <!--
      Assign the public properties.  This has no effect if they were
      specified on the command-line, in which case they are read-only.
    -->
    <AkvPackageVersion>$(_AkvPackageVersion)</AkvPackageVersion>
    <AkvAssemblyFileVersion>$(_AkvAssemblyFileVersion)</AkvAssemblyFileVersion>

  </PropertyGroup>

</Project>
