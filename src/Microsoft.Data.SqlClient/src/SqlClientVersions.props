<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    This file contains the Microsoft.Data.SqlClient (MDS) package version
    information.  It is separate from the .csproj files so these versions can
    be imported into the overall MDS build without including other project
    variables.

    Private properties, not intended to be set or used externally, are prefixed
    with an underscore (_).
  -->

  <!-- This file uses the BuildNumber property defined in Versions.props. -->

  <!-- Versioning Properties -->
  <PropertyGroup>
    <!--
      We accept two public properties to control versioning:

        MdsPackageVersion:
          - Used as the NuGet package version, both in the package file name
            and in the package metadata.
          - If not specified, defaults to:
              $(MdsDefaultMajorVersion).$(MdsDefaultMinorVersion).$(MdsDefaultPatchVersion)-dev.

        MdsAssemblyFileVersion:
          - Used as the value of the assembly attribute 'AssemblyFileVersion'
            generated by MSBuild.
          - If not specified:
            - If $(MdsPackageVersion) is specified, use the numeric
              parts of its value, for example 6.1.5.345.
            - Otherwise, defaults to:
              $(MdsDefaultMajorVersion).$(MdsDefaultMinorVersion).$(MdsDefaultPatchVersion).$(BuildNumber).

      We use private properties to hold the computed values, and then always
      assign those to the public properties.  After importing this file, the
      public properties will always be set.
    -->

    <!-- The default major, minor, and patch version numbers. -->
    <MdsDefaultMajorVersion>6</MdsDefaultMajorVersion>
    <MdsDefaultMinorVersion>1</MdsDefaultMinorVersion>
    <MdsDefaultPatchVersion>5</MdsDefaultPatchVersion>

    <!-- Determine the package version. -->
    <_MdsPackageVersion Condition="'$(MdsPackageVersion)' != ''">$(MdsPackageVersion)</_MdsPackageVersion>
    <_MdsPackageVersion Condition="'$(MdsPackageVersion)' == ''">$(MdsDefaultMajorVersion).$(MdsDefaultMinorVersion).$(MdsDefaultPatchVersion)-dev</_MdsPackageVersion>

    <!-- Determine the assembly file version. -->
    <!-- If MdsAssemblyFileVersion is set (e.g. from pipeline), use its value as-is. -->
    <_MdsAssemblyFileVersion Condition="'$(MdsAssemblyFileVersion)' != ''">$(MdsAssemblyFileVersion)</_MdsAssemblyFileVersion>
    <!-- If MdsPackageVersion is set, use its trimmed value. -->
    <_MdsAssemblyFileVersion Condition="'$(MdsAssemblyFileVersion)' == '' and '$(MdsPackageVersion)' != ''">$(MdsPackageVersion.Split('-')[0])</_MdsAssemblyFileVersion>
    <!-- If neither property is set, use the default value. -->
    <_MdsAssemblyFileVersion Condition="'$(MdsAssemblyFileVersion)' == '' and '$(MdsPackageVersion)' == ''">$(MdsDefaultMajorVersion).$(MdsDefaultMinorVersion).$(MdsDefaultPatchVersion).$(BuildNumber)</_MdsAssemblyFileVersion>

    <!--
      Assign the public properties.  This has no effect if they were
      specified on the command-line, in which case they are read-only.
    -->
    <MdsPackageVersion>$(_MdsPackageVersion)</MdsPackageVersion>
    <MdsAssemblyFileVersion>$(_MdsAssemblyFileVersion)</MdsAssemblyFileVersion>

  </PropertyGroup>

</Project>
