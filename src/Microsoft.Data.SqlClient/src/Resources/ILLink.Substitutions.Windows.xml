<linker>
  <assembly fullname="Microsoft.Data.SqlClient">
    <type fullname="Microsoft.Data.SqlClient.LocalAppContextSwitches">
      <!--
      Enable the unused SNI implementation to be trimmed based upon the publish-time
      value of the Switch.Microsoft.Data.SqlClient.UseManagedNetworkingOnWindows switch.

      This file is embedded ONLY on Windows builds (conditioned on NormalizedTargetOs
      in the csproj). On Unix, the UseManagedNetworking property compiles to a constant
      "=> true" via #elif NET, so no substitution is needed or desired — embedding these
      entries on Unix would be a breaking change if a cross-platform consumer sets the
      switch to false (intending it for Windows only), as the trimmer would stub the
      getter to false on Unix and break managed SNI.
      -->
      <method signature="System.Boolean get_UseManagedNetworking()"
              body="stub"
              value="false"
              feature="Switch.Microsoft.Data.SqlClient.UseManagedNetworkingOnWindows"
              featurevalue="false" />

      <method signature="System.Boolean get_UseManagedNetworking()"
              body="stub"
              value="true"
              feature="Switch.Microsoft.Data.SqlClient.UseManagedNetworkingOnWindows"
              featurevalue="true" />
    </type>
  </assembly>
</linker>
