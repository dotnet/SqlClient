<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    This file contains the Microsoft.SqlServer.Server package version
    information.  It is separate from the .csproj file so these versions can
    be imported into the overall MDS build without including other project
    variables.

    Private properties, not intended to be set or used externally, are prefixed
    with an underscore (_).
  -->

  <!-- This file uses the BuildNumber property defined in Versions.props. -->

  <!-- Versioning Properties -->
  <PropertyGroup>
    <!--
      We accept two public properties to control versioning:

        SqlServerPackageVersion:
          - Used as the NuGet package version, both in the package file name
            and in the package metadata.
          - If not specified, defaults to:
              $(SqlServerDefaultMajorVersion).$(SqlServerDefaultMinorVersion).$(SqlServerDefaultPatchVersion)-dev.

        SqlServerAssemblyFileVersion:
          - Used as the value of the assembly attribute 'AssemblyFileVersion'
            generated by MSBuild.
          - If not specified:
            - If $(SqlServerPackageVersion) is specified, use the numeric
              parts of its value, for example 1.0.0.345.
            - Otherwise, defaults to:
              $(SqlServerDefaultMajorVersion).$(SqlServerDefaultMinorVersion).$(SqlServerDefaultPatchVersion).$(BuildNumber).

      We use private properties to hold the computed values, and then always
      assign those to the public properties.  After importing this file, the
      public properties will always be set.
    -->

    <!-- The default major, minor, and patch version numbers. -->
    <SqlServerDefaultMajorVersion>1</SqlServerDefaultMajorVersion>
    <SqlServerDefaultMinorVersion>0</SqlServerDefaultMinorVersion>
    <SqlServerDefaultPatchVersion>0</SqlServerDefaultPatchVersion>

    <!-- Determine the package version. -->
    <_SqlServerPackageVersion Condition="'$(SqlServerPackageVersion)' != ''">$(SqlServerPackageVersion)</_SqlServerPackageVersion>
    <_SqlServerPackageVersion Condition="'$(SqlServerPackageVersion)' == ''">$(SqlServerDefaultMajorVersion).$(SqlServerDefaultMinorVersion).$(SqlServerDefaultPatchVersion)-dev</_SqlServerPackageVersion>

    <!-- Determine the assembly file version. -->
    <!-- If SqlServerAssemblyFileVersion is set, use its value as-is. -->
    <_SqlServerAssemblyFileVersion Condition="'$(SqlServerAssemblyFileVersion)' != ''">$(SqlServerAssemblyFileVersion)</_SqlServerAssemblyFileVersion>
    <!-- If SqlServerPackageVersion is set, use its trimmed value. -->
    <_SqlServerAssemblyFileVersion Condition="'$(SqlServerAssemblyFileVersion)' == '' and '$(SqlServerPackageVersion)' != ''">$(SqlServerPackageVersion.Split('-')[0])</_SqlServerAssemblyFileVersion>
    <!-- If neither property is set, use the default value. -->
    <_SqlServerAssemblyFileVersion Condition="'$(SqlServerAssemblyFileVersion)' == '' and '$(SqlServerPackageVersion)' == ''">$(SqlServerDefaultMajorVersion).$(SqlServerDefaultMinorVersion).$(SqlServerDefaultPatchVersion).$(BuildNumber)</_SqlServerAssemblyFileVersion>

    <!--
      Assign the public properties.  This has no effect if they were
      specified on the command-line, in which case they are read-only.
    -->
    <SqlServerPackageVersion>$(_SqlServerPackageVersion)</SqlServerPackageVersion>
    <SqlServerAssemblyFileVersion>$(_SqlServerAssemblyFileVersion)</SqlServerAssemblyFileVersion>

    <!--
      This sets the version of the Microsoft.SqlServer.Server assembly.  It
      should only be updated when a non-backwards compatible version is released.
      Only ever update the major version number.
    -->
    <SqlServerAssemblyVersion>1.0.0.0</SqlServerAssemblyVersion>

    <!-- Convenience alias used by build.proj. -->
    <SqlServerLibVersion>$(SqlServerPackageVersion)</SqlServerLibVersion>

  </PropertyGroup>

</Project>
