## .gitignore for Microsoft.Data.SqlClient

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# Visual Studio auto generated files
Generated\ Files/
**/.AssemblyAttributes

# Visual Studio Code settings
.vscode/*
!.vscode/mcp.json

# MSTest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# TRX format test results
**/*.trx

# Benchmark results
BenchmarkDotNet.Artifacts/

# .NET project lock files and build artifacts
project.lock.json
project.fragment.lock.json
artifacts/

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Visual Studio code coverage results
*.coverage
*.coveragexml

# NuGet packages
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/.gitkeep
.nuget/

# Output folder
**/[Oo]utput/*
!**/[Oo]utput/.gitkeep

# NuGet v3 project.json auxiliary files
*.nuget.props
*.nuget.targets

# Visual Studio cache files
*.[Cc]ache
# but keep directories ending in .cache
!?*.[Cc]ache/

# Temp and backup files
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings

# SQL Server data files
*.mdf
*.ldf
*.ndf

# Microsoft Fakes
FakesAssemblies/

# Node modules
node_modules/

# MSBuild binary and structured log
*.binlog

# Local History for Visual Studio
.localhistory/

# JetBrains Rider
.idea/

# Config Json file
**/config.json
**/config.jsonc

# Generated Milestone PR metadata files
.milestone-prs/

# MDS "Not Supported" GenAPI code
**/notsupported/*.cs

# C# language server cache
*.lscache
